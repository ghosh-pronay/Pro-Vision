# Pro-Vision Environment Variables
# Copy this file to .env.local and fill in the values

# Firebase Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=pro-visions.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pro-visions
VITE_FIREBASE_STORAGE_BUCKET=pro-visions.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=570621295453
VITE_FIREBASE_APP_ID=1:570621295453:web:3e2c03807274d8d4e286b4
VITE_FIREBASE_MEASUREMENT_ID=G-C6FC4FJXWX
VITE_FIREBASE_VAPID_KEY=

# Gemini API Key (for AI Coach)
# Get yours at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Convex (optional - leave empty to use localStorage)
# If not set, the app uses localStorage-backed data store
# If set, remove the Vite aliases in vite.config.ts for real Convex
VITE_CONVEX_URL=
