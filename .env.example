# Pro-Vision Environment Variables
# Copy this file to .env.local and fill in the values

# Firebase Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=your_vapid_key

# API keys are now server-side only (Cloud Functions)
# Set via: firebase functions:config:set gemini.api_key="YOUR_KEY"
# Set via: firebase functions:config:set groq.api_key="YOUR_KEY"

# Convex (optional - leave empty to use localStorage)
# If not set, the app uses localStorage-backed data store
# If set, remove the Vite aliases in vite.config.ts for real Convex
VITE_CONVEX_URL=
